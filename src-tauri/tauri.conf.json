{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EasyPaper",
  "version": "1.0.1",
  "identifier": "com.easypaper.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build:sidecar",
    "frontendDist": "../tauri-frontend"
  },
  "app": {
    "windows": [
      {
        "title": "EasyPaper",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self' http://localhost:* ws://localhost:*; img-src 'self' data: blob: http: https:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; font-src 'self' data:; connect-src 'self' http://localhost:* https: wss:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "../sidecar-dist/easypaper-server"
    ],
    "resources": {
      "../sidecar-dist/easypaper-server": "server/"
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}